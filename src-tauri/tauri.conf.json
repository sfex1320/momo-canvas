{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOMO-Canvas",
  "version": "0.3.0",
  "identifier": "site.jinpengi.momo",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MOMO 智能画布",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "maximized": true,
        "center": true,
        "decorations": false,
        "shadow": true,
        "dragDropEnabled": false,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --enable-gpu-rasterization --enable-zero-copy"
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**", "$APPDATA\\**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDUzMjRFNzg4MzAxQzVBNQpSV1NseFFHRGVFNHlCV20xV2Ntby82ZTlZdmV1QXdBTW45U3JSS1licXJXVzMvMTRLRWFtZDEwcgo=",
      "endpoints": [
        "https://github.com/sfex1320/momo-canvas/releases/latest/download/latest.json"
      ]
    }
  }
}
